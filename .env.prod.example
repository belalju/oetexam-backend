# Copy this file to .env on the server: cp .env.prod.example .env
# Fill in real values — never commit the actual .env file

DB_USERNAME=oetuser
DB_PASSWORD=change_me_strong_password

# Generate with: openssl rand -base64 64
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-at-least-64-chars-long

# Token expiry in milliseconds (defaults: 1h / 7d)
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=https://oet-app.belalhossain.dev

# Google Sign-In — OAuth 2.0 Web client ID (same one used by the Angular frontend)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# SMTP for verification emails (Gmail: use an App Password, not the account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user@gmail.com
SMTP_PASSWORD=your-smtp-app-password
MAIL_FROM=no-reply@oetpractice.com

# Frontend base URL used in verification email links
FRONTEND_BASE_URL=https://oet-app.belalhossain.dev
